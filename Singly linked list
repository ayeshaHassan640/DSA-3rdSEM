Node* stack[SIZE];
int top=-1;
void  push(Node* curr)
{
	if(top==SIZE-1)
	{
		cout<< "Stack Overflow.";
		return ;
		
		}	
		else
		{
			top++;
			stack[top]=curr;
		}
	}
Node* pop(){
	if(top==-1)
	{
		cout<< "Stack underflow.";
		return NULL;
	}
	
	return stack[top--];
	//top--;
}
