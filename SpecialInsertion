#include <iostream>
#include <stack>
using namespace std;

struct Node
{
    int data;
    Node* next;
};

Node* head = NULL;

// Length of Linked List
int length()
{
    int count = 0;
    Node* temp = head;

    while (temp != NULL)
    {
        count++;
        temp = temp->next;
    }

    return count;
}

// Insert at Beginning
void insertBeginning(int value)
{
    Node* newNode = new Node;
    newNode->data = value;
    newNode->next = head;
    head = newNode;
}

// Insert at End
void insertEnd(int value)
{
    Node* newNode = new Node;
    newNode->data = value;
    newNode->next = NULL;

    if (head == NULL)
    {
        head = newNode;
        return;
    }

    Node* temp = head;

    while (temp->next != NULL)
        temp = temp->next;

    temp->next = newNode;
}

// Insert at nth Position
void insertNth(int value)
{
    int n = value % 10;   // Last digit

    int len = length();

    // If position exists
    if (len >= n)
    {
        Node* newNode = new Node;
        newNode->data = value;

        // Position 1
        if (n == 1)
        {
            newNode->next = head;
            head = newNode;
            return;
        }

        Node* temp = head;

        // Move to (n-1)th node
        for (int i = 1; i < n - 1; i++)
            temp = temp->next;

        newNode->next = temp->next;
        temp->next = newNode;
    }
    else
    {
        // Position doesn't exist
        if (value % 2 != 0)
            insertBeginning(value);   // Odd
        else
            insertEnd(value);         // Even
    }
}

// Display
void display()
{
    Node* temp = head;

    while (temp != NULL)
    {
        cout << temp->data << " ";
        temp = temp->next;
    }
    cout << endl;
}

// Reverse Display using Iteration
void reverseDisplay()
{
    stack<int> s;

    Node* temp = head;

    while (temp != NULL)
    {
        s.push(temp->data);
        temp = temp->next;
    }

    while (!s.empty())
    {
        cout << s.top() << " ";
        s.pop();
    }

    cout << endl;
}

int main()
{
    // Sample List
    insertEnd(10);
    insertEnd(20);
    insertEnd(30);
    insertEnd(40);
    insertEnd(50);
    insertEnd(60);
    insertEnd(70);

    cout << "Original List:\n";
    display();

    insertNth(767);

    cout << "After Insertion:\n";
    display();

    cout << "Reverse Display:\n";
    reverseDisplay();
}
